# Get a free key (no credit card) at https://www.football-data.org/client/register
# Free tier: 10 requests/minute, covers PL, ELC, PD, SA, BL1, FL1, DED, PPL, BSA, CL, EC, WC
FOOTBALL_DATA_API_KEY=

# Protects /api/admin/* (sync trigger, feature-match, league toggle). Pick any
# long random string. Required before making the site public — without it,
# anyone who finds /admin can trigger syncs or edit data.
ADMIN_SECRET=

# Comma-separated frontend origin(s) allowed to call this API, e.g.
# http://localhost:3000,https://your-site.netlify.app
ALLOWED_ORIGINS=http://localhost:3000
