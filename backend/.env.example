# Real data now comes from SofaScore's public API (app/providers/sofascore.py)
# and needs NO API key or signup — it just works out of the box.
#
# Leagues currently mapped to a SofaScore tournament id (see
# app/providers/sofascore.py LEAGUE_ID_TO_SOFASCORE_ID) sync to real
# teams/standings/matches automatically on startup and once daily.
# Everything else stays on generated mock data. See docs/API_INTEGRATION.md
# for how to add more leagues.

# Optional legacy provider (app/providers/football_data.py), unused by
# default now. Only needed if you switch app/sync.py back to it.
FOOTBALL_DATA_API_KEY=
